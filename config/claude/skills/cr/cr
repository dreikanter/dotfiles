#!/usr/bin/env ruby
# cr - Code review of a GitHub PR against Jira ticket(s).
# Renders a self-contained HTML report with structured findings.
#
# Usage:
#   cr <pr_url> [JIRA-123 ...]
#
# Args may be in any order. PR URL is required. Jira IDs/URLs are optional;
# additional Jira references found in the PR description are also gathered.

require "json"
require "open3"
require "tempfile"
require "digest"
require "uri"
require "cgi"
require "fileutils"

USAGE = <<~TXT
  Usage: cr <pr_url> [JIRA-ID|JIRA_URL ...]

  Produces an HTML code-review report for the PR. Cross-references Jira
  ticket(s) for scope and acceptance criteria. Args may be in any order.
TXT

PR_URL_RE = %r{\Ahttps?://github\.com/[^/]+/[^/]+/pulls?/\d+\z}
JIRA_ID_RE = /\A[A-Z][A-Z0-9]+-\d+\z/
JIRA_URL_RE = %r{atlassian\.net/browse/([A-Z][A-Z0-9]+-\d+)}

CLAUDE_MODEL = ENV.fetch("CR_MODEL", "claude-opus-4-7")

FINDING_TYPES = %w[blocker bug suggestion question nitpick].freeze

def die(msg, code = 1)
  warn msg
  exit code
end

def have!(cmd)
  return if system("command -v #{cmd} >/dev/null 2>&1")
  die "Required command not found: #{cmd}"
end

def run!(*cmd, stdin: nil)
  out, err, status = Open3.capture3(*cmd, stdin_data: stdin || "")
  unless status.success?
    warn "Command failed: #{cmd.join(" ")}"
    warn err unless err.empty?
    exit(status.exitstatus || 1)
  end
  out
end

def parse_args(argv)
  if argv.empty? || argv.include?("-h") || argv.include?("--help")
    puts USAGE
    exit 0
  end

  pr_url = nil
  jira_refs = []

  argv.each do |arg|
    if arg =~ PR_URL_RE
      die "Multiple PR URLs given." if pr_url
      pr_url = arg
    elsif arg =~ JIRA_ID_RE
      jira_refs << arg
    elsif (m = arg.match(JIRA_URL_RE))
      jira_refs << m[1]
    else
      die "Unrecognized argument: #{arg}\n\n#{USAGE}"
    end
  end

  die "GitHub PR URL is required.\n\n#{USAGE}" unless pr_url
  [pr_url, jira_refs.uniq]
end

def parse_pr_url(url)
  m = url.match(%r{github\.com/([^/]+)/([^/]+)/pulls?/(\d+)})
  die "Invalid PR URL: #{url}" unless m
  [m[1], m[2], m[3]]
end

def parallel(*tasks)
  threads = tasks.map { |t| Thread.new { t.call } }
  threads.map(&:value)
end

def gather_pr_data(pr_url)
  prdump_out, diff_out = parallel(
    -> { run!("prdump", pr_url) },
    -> { run!("gh", "pr", "diff", pr_url) }
  )

  # Extract changed file paths from diff headers (b/PATH).
  files = diff_out.scan(%r{^diff --git a/.+ b/(.+)$}).flatten.uniq

  # Extract additional Jira references from the PR body section of prdump.
  extra_jira = prdump_out.scan(/\b[A-Z][A-Z0-9]+-\d+\b/).uniq

  [prdump_out, diff_out, files, extra_jira]
end

def gather_jira(jira_ids)
  return "" if jira_ids.empty?
  return "" unless system("command -v jiradump >/dev/null 2>&1")

  outputs = parallel(*jira_ids.map { |id| -> { [id, safe_run("jiradump", id)] } })
  outputs.map { |id, out| "## #{id}\n\n#{out}" }.join("\n\n")
end

def safe_run(*cmd)
  out, _err, status = Open3.capture3(*cmd)
  status.success? ? out : ""
end

def read_files(paths, max_bytes: 60_000)
  paths.map do |path|
    if File.file?(path)
      content = File.read(path, mode: "r:BINARY")
      content = content.byteslice(0, max_bytes) + "\n... (truncated)" if content.bytesize > max_bytes
      "### #{path}\n\n```\n#{content}\n```\n"
    elsif File.exist?(path)
      "### #{path}\n\n(directory or non-regular file; skipped)\n"
    else
      "### #{path}\n\n(not present in working tree; rely on diff)\n"
    end
  end.join("\n")
end

def sha256_hex(str)
  Digest::SHA256.hexdigest(str)
end

def build_prompt(pr_url, prdump_out, diff_out, jira_out, files_blob)
  schema = <<~SCHEMA
    {
      "summary": "string (1-2 sentences, plain prose)",
      "scope": {
        "in_scope": ["string"],
        "out_of_scope": ["string"],
        "missing": ["string"]
      },
      "findings": [
        {
          "path": "string (file path from diff)",
          "line": integer (1-based, primary line),
          "line_end": integer or null,
          "type": "blocker|bug|suggestion|question|nitpick",
          "problem": "string (lead with problem statement, declarative, no hedging)",
          "fix": "string or null (only if obvious)"
        }
      ]
    }
  SCHEMA

  <<~PROMPT
    You are performing a structured code review of a GitHub pull request,
    cross-referenced against Jira ticket(s) for scope and acceptance criteria.

    Output ONLY a JSON object matching this schema. No markdown, no prose
    outside JSON, no code fences:

    #{schema}

    ## Review principles

    Architecture first: assess the overall approach before line-level details.
    If the architecture is wrong, focus findings on that.

    Do no harm: never propose broken code; describe ideas in prose if unsure.
    Understand the domain before flagging issues. Do not flag hypothetical
    problems that cannot happen in this codebase.

    Be specific. No hedge language ("might", "could potentially"). No praise.
    Lead each finding with the problem statement.

    Prioritize substantive findings. Keep scope assessment concise; omit
    bullets that add no information. If no Jira tickets are provided, return
    empty arrays for scope.in_scope, scope.out_of_scope, scope.missing.

    Finding types:
      blocker     — must be resolved before merge
      bug         — defect, edge case, or regression risk
      suggestion  — meaningful improvement worth acting on
      question    — unclear intent; needs author input
      nitpick     — cosmetic or style; non-blocking

    ## PR Data (from prdump)

    #{prdump_out}

    ## Diff

    ```diff
    #{diff_out}
    ```

    ## Jira Tickets

    #{jira_out.empty? ? "(none provided)" : jira_out}

    ## Modified files (current working-tree contents)

    #{files_blob}

    Output the JSON object now.
  PROMPT
end

def call_claude(prompt)
  out, err, status = Open3.capture3(
    "claude", "--model", CLAUDE_MODEL, "--print", prompt
  )
  unless status.success?
    warn "claude CLI failed:"
    warn err
    exit(status.exitstatus || 1)
  end
  out
end

def extract_json(text)
  # Strip markdown fences if present.
  cleaned = text.strip
  cleaned = cleaned.sub(/\A```(?:json)?\s*/, "").sub(/\s*```\z/, "")

  # Find first '{' and matching last '}'.
  start = cleaned.index("{")
  finish = cleaned.rindex("}")
  die "No JSON object found in model output:\n#{text}" unless start && finish

  JSON.parse(cleaned[start..finish])
rescue JSON::ParserError => e
  die "Failed to parse JSON from model:\n#{e.message}\n\n#{text}"
end

def normalize_review(data)
  data["summary"] = data["summary"].to_s
  data["scope"] ||= {}
  %w[in_scope out_of_scope missing].each do |k|
    data["scope"][k] = Array(data["scope"][k]).map(&:to_s).reject(&:empty?)
  end
  data["findings"] = Array(data["findings"]).map do |f|
    {
      "path"     => f["path"].to_s,
      "line"     => (f["line"] || 1).to_i,
      "line_end" => f["line_end"].nil? ? nil : f["line_end"].to_i,
      "type"     => FINDING_TYPES.include?(f["type"]) ? f["type"] : "suggestion",
      "problem"  => f["problem"].to_s,
      "fix"      => (f["fix"].nil? || f["fix"].to_s.empty?) ? nil : f["fix"].to_s
    }
  end
  data
end

def link_for(owner, repo, pr_number, finding, sha_cache)
  path = finding["path"]
  return nil if path.empty?
  hex = sha_cache[path] ||= sha256_hex(path)
  range = finding["line_end"] ? "R#{finding["line"]}-R#{finding["line_end"]}" : "R#{finding["line"]}"
  "https://github.com/#{owner}/#{repo}/pull/#{pr_number}/changes#diff-#{hex}#{range}"
end

