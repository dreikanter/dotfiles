        filtersEl.appendChild(wrap);
        wrap.querySelector("input").addEventListener("change", e => {
          state.hidden[t] = !e.target.checked;
          applyFilters(); save();
        });
      });

      function applyFilters() {
        findings.forEach(f => {
          f.style.display = state.hidden[f.dataset.type] ? "none" : "";
        });
        updateCounter();
      }

      function updateCounter() {
        const visible = findings.filter(f => f.style.display !== "none");
        const addressed = visible.filter(f => f.classList.contains("addressed"));
        document.getElementById("counter").textContent =
          visible.length + " · " + addressed.length + " addressed";
      }

      function select(id) {
        findings.forEach(f => f.classList.toggle("selected", f.dataset.id === id));
        state.selected = id;
        save();
      }

      findings.forEach(f => {
        const id = f.dataset.id;
        if (state.addressed[id]) f.classList.add("addressed");
        if (state.selected === id) f.classList.add("selected");

        f.addEventListener("click", e => {
          if (e.target.tagName === "A" || e.target.tagName === "INPUT") return;
          select(id);
        });

        const cb = f.querySelector(".addressed-toggle input");
        cb.checked = !!state.addressed[id];
        cb.addEventListener("change", () => {
          state.addressed[id] = cb.checked;
          f.classList.toggle("addressed", cb.checked);
          updateCounter(); save();
        });
      });

      document.getElementById("reset").addEventListener("click", () => {
        state.addressed = {};
        findings.forEach(f => {
          f.classList.remove("addressed");
          f.querySelector(".addressed-toggle input").checked = false;
        });
        updateCounter(); save();
      });

      // Keyboard navigation: j/k to move selection.
      document.addEventListener("keydown", e => {
        if (e.target.tagName === "INPUT") return;
        if (e.key !== "j" && e.key !== "k") return;
        const visible = findings.filter(f => f.style.display !== "none");
        if (!visible.length) return;
        const cur = visible.findIndex(f => f.classList.contains("selected"));
        let next = e.key === "j" ? cur + 1 : cur - 1;
        if (next < 0) next = 0;
        if (next >= visible.length) next = visible.length - 1;
        select(visible[next].dataset.id);
        visible[next].scrollIntoView({ block: "center", behavior: "smooth" });
      });

      applyFilters();
    })();
