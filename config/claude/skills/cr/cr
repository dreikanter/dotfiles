def html_escape(s)
  CGI.escapeHTML(s.to_s)
end

def render_finding(f, idx, link)
  loc = "#{f["path"]}:#{f["line"]}"
  loc += "-#{f["line_end"]}" if f["line_end"]
  loc_html = link ? %(<a href="#{html_escape(link)}" target="_blank" rel="noopener">#{html_escape(loc)}</a>) : html_escape(loc)
  fix_html = f["fix"] ? %(<div class="finding-fix">#{html_escape(f["fix"])}</div>) : ""

  <<~HTML
    <div class="finding" data-id="f#{idx}" data-type="#{html_escape(f["type"])}">
      <div class="finding-head">
        <span class="badge #{html_escape(f["type"])}">#{html_escape(f["type"])}</span>
        <span class="finding-loc">#{loc_html}</span>
        <label class="addressed-toggle">
          <input type="checkbox"> addressed
        </label>
      </div>
      <div class="finding-body">
        <p>#{html_escape(f["problem"])}</p>
        #{fix_html}
      </div>
    </div>
  HTML
end

def render_scope(scope)
  in_scope = scope["in_scope"]
  out_scope = scope["out_of_scope"]
  missing = scope["missing"]

  return "" if in_scope.empty? && out_scope.empty? && missing.empty?

  cards = []
  cards << render_scope_card("In-Scope", in_scope) unless in_scope.empty?
  cards << render_scope_card("Out-of-Scope", out_scope) unless out_scope.empty?
  cards << render_scope_card("Missing from Ticket", missing) unless missing.empty?

  <<~HTML
    <h2>Scope Assessment</h2>
    <div class="scope-grid">#{cards.join}</div>
  HTML
end

def render_scope_card(title, items)
  body = if items.empty?
    %(<p class="empty">None.</p>)
  else
    "<ul>#{items.map { |i| "<li>#{html_escape(i)}</li>" }.join}</ul>"
  end
  %(<div class="scope-card"><h3>#{html_escape(title)}</h3>#{body}</div>)
end

def extract_meta(prdump_out)
  title  = prdump_out[/^# (.+)$/, 1] || "Code Review"
  branch = prdump_out[/^Branch: `([^`]+)`/, 1] || ""
  author = prdump_out[/^Author: \*\*(.+?)\*\*/, 1] || ""
  { title: title, branch: branch, author: author }
end

def render_html(pr_url, owner, repo, pr_number, prdump_out, review)
  meta = extract_meta(prdump_out)
  sha_cache = {}

  findings_html = review["findings"].each_with_index.map do |f, i|
    render_finding(f, i, link_for(owner, repo, pr_number, f, sha_cache))
  end.join

  findings_html = %(<p class="empty">No findings.</p>) if review["findings"].empty?

  storage_key = sha256_hex(pr_url)[0, 16].inspect

  HTML_TEMPLATE
    .sub("__TITLE__", html_escape("CR: #{meta[:title]}"))
    .sub("__PR_TITLE__", html_escape(meta[:title]))
    .sub("__PR_URL__", html_escape(pr_url))
    .sub("__PR_URL__", html_escape(pr_url))
    .sub("__BRANCH__", html_escape(meta[:branch]))
    .sub("__AUTHOR__", html_escape(meta[:author]))
    .sub("__SUMMARY__", html_escape(review["summary"]))
    .sub("__FINDINGS__", findings_html)
    .sub("__SCOPE_SECTION__", render_scope(review["scope"]))
    .sub("__STORAGE_KEY__", storage_key)
end

# --- main -------------------------------------------------------------------

if $PROGRAM_NAME == __FILE__
pr_url, jira_args = parse_args(ARGV)

have!("gh")
have!("prdump")
have!("claude")

owner, repo, pr_number = parse_pr_url(pr_url)

warn "Gathering PR data..."
prdump_out, diff_out, files, extra_jira = gather_pr_data(pr_url)

jira_ids = (jira_args + extra_jira).uniq
warn "Gathering Jira context (#{jira_ids.size} ticket(s))..." unless jira_ids.empty?
jira_out = gather_jira(jira_ids)

warn "Reading #{files.size} modified file(s)..."
files_blob = read_files(files)

warn "Calling claude (#{CLAUDE_MODEL})..."
prompt = build_prompt(pr_url, prdump_out, diff_out, jira_out, files_blob)
raw = call_claude(prompt)
review = normalize_review(extract_json(raw))

html = render_html(pr_url, owner, repo, pr_number, prdump_out, review)
out_path = File.join(Dir.tmpdir, "cr-#{owner}-#{repo}-#{pr_number}-#{Time.now.to_i}.html")
File.write(out_path, html)

puts out_path
end
