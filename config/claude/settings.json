{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh search prs*)",
      "Bash(gh api /notifications*)",
      "Bash(gh api notifications*)",
      "Bash(acli jira*)",
      "Bash(jira-inbox*)",
      "Bash(date*)",
      "Bash(printf*)",
      "Bash(notes *)",
      "mcp__claude_ai_Slack__slack_search_public_and_private",
      "mcp__claude_ai_Slack__slack_read_thread",
      "mcp__claude_ai_Slack__slack_read_channel",
      "Read",
      "Write(/Users/alex/dailydispatch/*)",
      "Bash(source ~/.zshenv && prdump *)",
      "Bash(source ~/.zshenv && jiradump *)",
      "Bash(bundle exec rubocop --parallel --force-exclusion *)",
      "Bash(gh pr diff*)",
      "Bash(echo -n * | shasum -a 256)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__github__create_pull_request|mcp__github__update_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/strip-gh-pr-attribution.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-end-test.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "revdiff@revdiff": true
  },
  "extraKnownMarketplaces": {
    "revdiff": {
      "source": {
        "source": "github",
        "repo": "umputun/revdiff"
      }
    }
  },
  "skipAutoPermissionPrompt": true
}
