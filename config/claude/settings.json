{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh search prs*)",
      "Bash(gh api /notifications*)",
      "Bash(acli jira*)",
      "Bash(date*)",
      "Bash(printf*)",
      "Bash(notes *)",
      "mcp__claude_ai_Slack__slack_search_public_and_private",
      "Bash(source ~/.zshenv && prdump *)",
      "Bash(source ~/.zshenv && jiradump *)",
      "Bash(bundle exec rubocop --parallel --force-exclusion *)"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true
  }
}
