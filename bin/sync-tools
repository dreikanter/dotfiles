#!/usr/bin/env bash
set -euo pipefail

export GOPROXY=direct

go install github.com/dreikanter/notes/cmd/notes@latest
notes --version
echo

go install github.com/dreikanter/npub/cmd/npub@latest
npub --version
echo

go install github.com/dreikanter/nview/cmd/nview@latest
nview --version
echo

go install github.com/dreikanter/dotfiles-cli/cmd/dotfiles@latest
dotfiles --version
echo

echo "Done."
