#!/usr/bin/env bash
set -euo pipefail

GOPROXY=direct

go install github.com/dreikanter/notes-cli/cmd/notes@latest
notes --version

go install github.com/dreikanter/npub/cmd/npub@latest
npub --version

go install github.com/dreikanter/notes-view/cmd/notesview@latest
notesview --version

echo "Done."
