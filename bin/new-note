#!/usr/bin/env bash

set -euo pipefail

if ! command -v notes &>/dev/null; then
  echo "Error: 'notes' CLI not found in PATH. Install it first." >&2
  exit 1
fi

file_path=$(notes new)
echo "$file_path"

${NOTES_EDITOR:-/opt/homebrew/bin/subl --add} "${NOTES_PATH:-$HOME/Dropbox/Notes}" "$file_path" &
disown
